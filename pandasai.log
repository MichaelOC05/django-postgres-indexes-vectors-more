male_survivors = survival_by_sex[survival_by_sex['Sex'] == 'male']['survivors'].iloc[0]
female_rate = survival_by_sex[survival_by_sex['Sex'] == 'female']['survival_rate_percent'].iloc[0]
male_rate = survival_by_sex[survival_by_sex['Sex'] == 'male']['survival_rate_percent'].iloc[0]

