import pandas as pd
import matplotlib.pyplot as plt

# Get survival data by sex
sql_query = """
SELECT 
    Sex,
    Survived,
    COUNT(*) as count
FROM table_titanic_data 
GROUP BY Sex, Survived
ORDER BY Sex, Survived
"""

survival_data = execute_sql_query(sql_query)

# Prepare data for histogram
male_survived = survival_data[(survival_data['Sex'] == 'male') & (survival_data['Survived'] == 1)]['count'].iloc[0]
male_died = survival_data[(survival_data['Sex'] == 'male') & (survival_data['Survived'] == 0)]['count'].iloc[0]
female_survived = survival_data[(survival_data['Sex'] == 'female') & (survival_data['Survived'] == 1)]['count'].iloc[0]
female_died = survival_data[(survival_data['Sex'] == 'female') & (survival_data['Survived'] == 0)]['count'].iloc[0]

# Create histogram
fig, ax = plt.subplots(figsize=(10, 6))

# Data for plotting
categories = ['Male', 'Female']
survived_counts = [male_survived, female_survived]
died_counts = [male_died, female_died]

# Create grouped bar chart (histogram)
x_pos = range(len(categories))
width = 0.35

bars1 = ax.bar([x - width/2 for x in x_pos], died_counts, width, label='Died', color='red', alpha=0.7)
bars2 = ax.bar([x + width/2 for x in x_pos], survived_counts, width, label='Survived', color='green', alpha=0.7)

# Customize the plot
ax.set_xlabel('Sex')
ax.set_ylabel('Number of Passengers')
ax.set_title('Titanic Survival Histogram by Sex')
ax.set_xticks(x_pos)
ax.set_xticklabels(categories)
ax.legend()

# Add value labels on bars
for bar in bars1:
    height = bar.get_height()
    ax.text(bar.get_x() + bar.get_width()/2., height + 1,
            f'{int(height)}', ha='center', va='bottom')

for bar in bars2:
    height = bar.get_height()
    ax.text(bar.get_x() + bar.get_width()/2., height + 1,
            f'{int(height)}', ha='center', va='bottom')

plt.tight_layout()
plt.savefig('survival_histogram_by_sex.png', dpi=300, bbox_inches='tight')
plt.close()

