import pandas as pd
import matplotlib.pyplot as plt

# First, let's analyze survival rates by passenger class
sql_query = """
SELECT 
    Pclass,
    COUNT(*) as total_passengers,
    SUM(Survived) as survivors,
    ROUND(AVG(Survived) * 100, 2) as survival_rate_percent
FROM table_titanic_data 
GROUP BY Pclass
ORDER BY Pclass
"""

survival_by_class = execute_sql_query(sql_query)

# Create a visualization to show the correlation
plt.figure(figsize=(10, 6))

# Create subplot with bar chart
plt.subplot(1, 2, 1)
plt.bar(survival_by_class['Pclass'], survival_by_class['survival_rate_percent'], 
        color=['gold', 'silver', 'brown'], alpha=0.7)
plt.xlabel('Passenger Class')
plt.ylabel('Survival Rate (%)')
plt.title('Survival Rate by Passenger Class')
plt.xticks(survival_by_class['Pclass'], ['1st Class', '2nd Class', '3rd Class'])

# Add value labels on bars
for i, v in enumerate(survival_by_class['survival_rate_percent']):
    plt.text(i+1, v+1, f'{v}%', ha='center', va='bottom', fontweight='bold')

# Create subplot with passenger counts
plt.subplot(1, 2, 2)
plt.bar(survival_by_class['Pclass'], survival_by_class['total_passengers'], 
        color=['lightblue', 'lightgreen', 'lightcoral'], alpha=0.7)
plt.xlabel('Passenger Class')
plt.ylabel('Total Passengers')
plt.title('Total Passengers by Class')
plt.xticks(survival_by_class['Pclass'], ['1st Class', '2nd Class', '3rd Class'])

# Add value labels on bars
for i, v in enumerate(survival_by_class['total_passengers']):
    plt.text(i+1, v+10, str(v), ha='center', va='bottom', fontweight='bold')

plt.tight_layout()
plt.savefig('class_survival_analysis.png', dpi=300, bbox_inches='tight')
plt.close()

# Calculate correlation coefficient between class and survival
sql_correlation_query = """
SELECT 
    CORR(Pclass, Survived) as correlation_coefficient
FROM table_titanic_data
"""

correlation_result = execute_sql_query(sql_correlation_query)
correlation_coeff = round(correlation_result.iloc[0]['correlation_coefficient'], 4)

# Prepare detailed analysis
