import pandas as pd
import matplotlib.pyplot as plt

# SQL query to get survivor count by sex
sql_query = """
SELECT 
    Sex,
    COUNT(*) as total_passengers,
    SUM(Survived) as survivors,
    SUM(CASE WHEN Survived = 0 THEN 1 ELSE 0 END) as non_survivors
FROM table_titanic_data 
GROUP BY Sex
ORDER BY Sex
"""

survival_by_sex = execute_sql_query(sql_query)

# Create the chart
plt.figure(figsize=(10, 6))

# Extract data for plotting
sexes = survival_by_sex['Sex']
survivors = survival_by_sex['survivors']
non_survivors = survival_by_sex['non_survivors']

# Create bar chart
x_pos = range(len(sexes))
width = 0.35

plt.bar([x - width/2 for x in x_pos], survivors, width, label='Survivors', color='lightgreen', alpha=0.8)
plt.bar([x + width/2 for x in x_pos], non_survivors, width, label='Non-survivors', color='lightcoral', alpha=0.8)

# Customize the chart
plt.xlabel('Sex', fontsize=12)
plt.ylabel('Number of Passengers', fontsize=12)
plt.title('Titanic Survivor Count by Sex', fontsize=14, fontweight='bold')
plt.xticks(x_pos, sexes)
plt.legend()
plt.grid(axis='y', alpha=0.3)

# Add value labels on bars
for i, (survivors_count, non_survivors_count) in enumerate(zip(survivors, non_survivors)):
    plt.text(i - width/2, survivors_count + 5, str(survivors_count), ha='center', va='bottom')
    plt.text(i + width/2, non_survivors_count + 5, str(non_survivors_count), ha='center', va='bottom')

plt.tight_layout()
plt.savefig('survivor_count_by_sex.png', dpi=300, bbox_inches='tight')
plt.show()

