import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Query to get survival data by sex
sql_query = """
SELECT 
    Sex,
    Survived,
    COUNT(*) as count
FROM table_titanic_data 
GROUP BY Sex, Survived
ORDER BY Sex, Survived
"""

survival_by_sex = execute_sql_query(sql_query)

# Pivot the data for easier plotting
pivot_data = survival_by_sex.pivot(index='Sex', columns='Survived', values='count').fillna(0)
pivot_data.columns = ['Did not survive', 'Survived']

# Create the histogram plot
plt.figure(figsize=(10, 6))
ax = pivot_data.plot(kind='bar', color=['#ff6b6b', '#4ecdc4'], alpha=0.8, width=0.7)

plt.title('Survival by Sex on the Titanic', fontsize=16, fontweight='bold', pad=20)
plt.xlabel('Sex', fontsize=12, fontweight='bold')
plt.ylabel('Number of Passengers', fontsize=12, fontweight='bold')
plt.legend(title='Outcome', title_fontsize=12, fontsize=10)
plt.xticks(rotation=0)
plt.grid(axis='y', alpha=0.3)

# Add value labels on bars
for container in ax.containers:
    ax.bar_label(container, fmt='%d', fontsize=10, fontweight='bold')

plt.tight_layout()
plt.savefig('survival_histogram_by_sex.png', dpi=300, bbox_inches='tight')
plt.close()

result = {'type': 'plot', 'value': 'survival_histogram_by_sex.png'}
