import pandas as pd
import matplotlib.pyplot as plt

# First, let's analyze survival rates by passenger class
sql_query = """
SELECT 
    Pclass,
    COUNT(*) as total_passengers,
    SUM(Survived) as survivors,
    ROUND(AVG(Survived) * 100, 2) as survival_rate_percent
FROM table_titanic_data 
GROUP BY Pclass
ORDER BY Pclass
"""

survival_by_class = execute_sql_query(sql_query)

# Create a visualization to show the correlation
plt.figure(figsize=(10, 6))

# Create bar chart
plt.subplot(1, 2, 1)
plt.bar(survival_by_class['Pclass'], survival_by_class['survival_rate_percent'], 
        color=['#1f77b4', '#ff7f0e', '#2ca02c'])
plt.xlabel('Passenger Class')
plt.ylabel('Survival Rate (%)')
plt.title('Survival Rate by Passenger Class')
plt.xticks([1, 2, 3], ['1st Class', '2nd Class', '3rd Class'])
for i, v in enumerate(survival_by_class['survival_rate_percent']):
    plt.text(i+1, v+1, f'{v}%', ha='center', va='bottom')

# Create stacked bar chart showing total passengers vs survivors
plt.subplot(1, 2, 2)
died = survival_by_class['total_passengers'] - survival_by_class['survivors']
plt.bar(survival_by_class['Pclass'], died, label='Died', color='#d62728')
plt.bar(survival_by_class['Pclass'], survival_by_class['survivors'], 
        bottom=died, label='Survived', color='#2ca02c')
plt.xlabel('Passenger Class')
plt.ylabel('Number of Passengers')
plt.title('Passenger Distribution by Class and Survival')
plt.xticks([1, 2, 3], ['1st Class', '2nd Class', '3rd Class'])
plt.legend()

plt.tight_layout()
plt.savefig('class_survival_analysis.png', dpi=300, bbox_inches='tight')
plt.close()

# Calculate correlation coefficient between class and survival
sql_correlation = """
SELECT 
    CORR(CAST(Pclass AS FLOAT), CAST(Survived AS FLOAT)) as correlation_coefficient
FROM table_titanic_data
"""
correlation_result = execute_sql_query(sql_correlation)
correlation_coeff = round(correlation_result.iloc[0]['correlation_coefficient'], 3)

# Create summary analysis
class_1_rate = survival_by_class[survival_by_class['Pclass'] == 1]['survival_rate_percent'].iloc[0]
class_2_rate = survival_by_class[survival_by_class['Pclass'] == 2]['survival_rate_percent'].iloc[0]
class_3_rate = survival_by_class[survival_by_class['Pclass'] == 3]['survival_rate_percent'].iloc[0]

analysis = f"""There is a strong negative correlation (r = {correlation_coeff}) between passenger class and survival rate on the Titanic. 

Key findings:
• 1st Class passengers had the highest survival rate at {class_1_rate}%
• 2nd Class passengers had a {class_2_rate}% survival rate
• 3rd Class passengers had the lowest survival rate at {class_3_rate}%

This shows that higher class passengers (lower class numbers) were significantly more likely to survive, likely due to better cabin locations and priority access to lifeboats."""

result = {'type': 'string', 'value': analysis}
