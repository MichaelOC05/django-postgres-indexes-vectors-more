plt.subplot(1, 2, 2)
plt.bar(survival_by_class['Pclass'], survival_by_class['total_passengers'], 
        color=['lightblue', 'lightgreen', 'lightcoral'], alpha=0.7)
plt.xlabel('Passenger Class')
plt.ylabel('Total Passengers')
plt.title('Total Passengers by Class')
plt.xticks(survival_by_class['Pclass'], ['1st Class', '2nd Class', '3rd Class'])

# Add value labels on bars
for i, v in enumerate(survival_by_class['total_passengers']):
    plt.text(survival_by_class['Pclass'].iloc[i], v + 5, str(v), ha='center')

plt.tight_layout()
plt.savefig('class_survival_analysis.png', dpi=300, bbox_inches='tight')
plt.close()

