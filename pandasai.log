highest_survival_rate = survival_by_sex.iloc[0]['Survival_Rate_Percent']

# Declare result var: 
result = {
    "type": "string", 
    "value": f"Females were most likely to have survived with a survival rate of {highest_survival_rate}% compared to males."
}
