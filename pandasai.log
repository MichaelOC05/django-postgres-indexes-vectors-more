import pandas as pd
import matplotlib.pyplot as plt

# First, let's analyze survival rate by passenger class
sql_query = """
SELECT 
    Pclass,
    COUNT(*) as total_passengers,
    SUM(Survived) as survivors,
    ROUND(AVG(Survived) * 100, 2) as survival_rate_percent
FROM table_titanic_data 
GROUP BY Pclass
ORDER BY Pclass
"""

survival_by_class = execute_sql_query(sql_query)

# Create a visualization to show the correlation
plt.figure(figsize=(10, 6))

# Create a bar chart showing survival rates by class
plt.subplot(1, 2, 1)
plt.bar(survival_by_class['Pclass'], survival_by_class['survival_rate_percent'], 
        color=['gold', 'silver', 'brown'], alpha=0.7)
plt.title('Survival Rate by Passenger Class')
plt.xlabel('Passenger Class')
plt.ylabel('Survival Rate (%)')
plt.ylim(0, 100)

# Add value labels on bars
for i, v in enumerate(survival_by_class['survival_rate_percent']):
    plt.text(survival_by_class['Pclass'][i], v + 2, f'{v}%', ha='center', va='bottom')

# Create a second chart showing total passengers and survivors
plt.subplot(1, 2, 2)
x = range(len(survival_by_class))
width = 0.35
plt.bar([i - width/2 for i in x], survival_by_class['total_passengers'], 
        width, label='Total Passengers', alpha=0.7)
plt.bar([i + width/2 for i in x], survival_by_class['survivors'], 
        width, label='Survivors', alpha=0.7)
plt.title('Passengers vs Survivors by Class')
plt.xlabel('Passenger Class')
plt.ylabel('Number of Passengers')
plt.xticks(x, survival_by_class['Pclass'])
plt.legend()

plt.tight_layout()
plt.savefig('class_survival_analysis.png', dpi=300, bbox_inches='tight')
plt.close()

# Calculate correlation coefficient
correlation_coeff = survival_by_class['Pclass'].corr(survival_by_class['survival_rate_percent'])

# Create summary analysis
class_1_rate = survival_by_class[survival_by_class['Pclass'] == 1]['survival_rate_percent'].iloc[0]
class_2_rate = survival_by_class[survival_by_class['Pclass'] == 2]['survival_rate_percent'].iloc[0]
class_3_rate = survival_by_class[survival_by_class['Pclass'] == 3]['survival_rate_percent'].iloc[0]

analysis = f"""Analysis of Passenger Class and Survival Rate:

There is a strong negative correlation between passenger class and survival rate (correlation: {correlation_coeff:.3f}).

Key findings:
• 1st Class passengers had the highest survival rate: {class_1_rate}%
• 2nd Class passengers had a moderate survival rate: {class_2_rate}%
• 3rd Class passengers had the lowest survival rate: {class_3_rate}%

This shows that higher social class (lower class number) was strongly associated with better survival chances on the Titanic. The difference between 1st and 3rd class survival rates is {class_1_rate - class_3_rate:.1f} percentage points."""

result = {'type': 'string', 'value': analysis}
