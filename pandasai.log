import matplotlib.pyplot as plt

# SQL query to get survivor count by sex
sql_query = """
SELECT 
    Sex,
    COUNT(*) as total_passengers,
    SUM(Survived) as survivors,
    COUNT(*) - SUM(Survived) as non_survivors,
    ROUND(AVG(Survived) * 100, 2) as survival_rate_percent
FROM table_titanic_data 
GROUP BY Sex
ORDER BY survivors DESC
"""

survival_by_sex = execute_sql_query(sql_query)

# Create the chart
plt.figure(figsize=(12, 6))

# Subplot 1: Survivor count by sex
plt.subplot(1, 2, 1)
bars = plt.bar(survival_by_sex['Sex'], survival_by_sex['survivors'], 
               color=['lightcoral', 'lightblue'], alpha=0.8)
plt.title('Survivor Count by Sex', fontsize=14, fontweight='bold')
plt.xlabel('Sex')
plt.ylabel('Number of Survivors')

# Add value labels on bars
for i, v in enumerate(survival_by_sex['survivors']):
    plt.text(i, v + 5, str(v), ha='center', va='bottom', fontweight='bold')

# Subplot 2: Total passengers vs survivors by sex
plt.subplot(1, 2, 2)
x = range(len(survival_by_sex))
width = 0.35

plt.bar([i - width/2 for i in x], survival_by_sex['total_passengers'], 
        width, label='Total Passengers', alpha=0.7, color='gray')
plt.bar([i + width/2 for i in x], survival_by_sex['survivors'], 
        width, label='Survivors', alpha=0.8, color='green')

plt.title('Total Passengers vs Survivors by Sex', fontsize=14, fontweight='bold')
plt.xlabel('Sex')
plt.ylabel('Number of People')
plt.xticks(x, survival_by_sex['Sex'])
plt.legend()

plt.tight_layout()

# Save the plot
plt.savefig('survivor_count_by_sex.png', dpi=300, bbox_inches='tight')
plt.show()

# Print detailed statistics
