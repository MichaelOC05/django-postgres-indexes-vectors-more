import pandas as pd

# Write code here

# Query to find survival rates by sex
sql_query = """
SELECT 
    Sex,
    COUNT(*) as Total_Count,
    SUM(Survived) as Survived_Count,
    ROUND(AVG(Survived) * 100, 2) as Survival_Rate_Percent
FROM table_titanic_data 
GROUP BY Sex
ORDER BY Survival_Rate_Percent DESC
"""

# Execute the query
